{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowS3AccessToSpecificBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::dev-application-bucket-REPLACE-ME",
        "arn:aws:s3:::dev-application-bucket-REPLACE-ME/*"
      ]
    },
    {
      "Sid": "AllowCloudWatchLogsRead",
      "Effect": "Allow",
      "Action": [
        "logs:GetLogEvents",
        "logs:FilterLogEvents",
        "logs:DescribeLogGroups",
        "logs:DescribeLogStreams"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenySecurityInfrastructure",
      "Effect": "Deny",
      "Action": [
        "iam:*",
        "cloudtrail:*",
        "config:*",
        "organizations:*",
        "account:*"
      ],
      "Resource": "*"
    }
  ]
}
